# Ignore all real .env files (secrets)
**/.env

# Ignore node_modules everywhere
**/node_modules

# Ignore build outputs
**/dist
**/.next
**/out
**/*.tsbuildinfo

# Ignore backup files
infra/backups/*.sql.gz
infra/backups/*.gpg

# Ignore Traefik acme certs (auto-generated)
infra/traefik/certs/

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
