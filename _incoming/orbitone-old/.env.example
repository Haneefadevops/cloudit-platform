# OrbitOne local development

# Backend
NODE_ENV=development
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=af74b8baff11a1d58a4ffc0d14e3c9851081e2ccac4c955f3fb95a924fc23180ad4234e0a4e651b6359c5ab880c6d044a3a6ad7b2ec50f33f9eae13727c78569s

# Google Calendar OAuth. Create these in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/v1/scheduling/google/callback

# Zoho Calendar OAuth. Create these in Zoho API Console.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_CALENDAR_REDIRECT_URI=http://localhost:8000/api/v1/scheduling/zoho/callback
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_CALENDAR_SCOPES=ZohoCalendar.calendar.ALL,ZohoCalendar.event.ALL

CALENDAR_TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Local services for running backend outside Docker
DATABASE_URL=postgres://orbitone:orbitone@localhost:5432/orbitone_local
REDIS_URL=redis://localhost:6379

# Docker Compose PostgreSQL settings
POSTGRES_USER=orbitone
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=orbitone_local

# For .env.test, use:
# NODE_ENV=production
# FRONTEND_ORIGIN=https://to1.cloudit.lk
# NEXT_PUBLIC_APP_URL=https://to1.cloudit.lk
# NEXT_PUBLIC_API_BASE_URL=https://to1.cloudit.lk/api/v1
# DATABASE_URL=postgres://orbitone:replace-with-strong-password@postgres:5432/orbitone_test
# REDIS_URL=redis://redis:6379
# POSTGRES_DB=orbitone_test

# For .env.prod, use:
# NODE_ENV=production
# FRONTEND_ORIGIN=https://po1.cloudit.lk
# NEXT_PUBLIC_APP_URL=https://po1.cloudit.lk
# NEXT_PUBLIC_API_BASE_URL=https://po1.cloudit.lk/api/v1
# DATABASE_URL=postgres://orbitone:replace-with-strong-password@postgres:5432/orbitone_prod
# REDIS_URL=redis://redis:6379
# POSTGRES_DB=orbitone_prod

# Public URLs
LOCAL_FRONTEND_URL=http://localhost:3000
LOCAL_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
TEST_FRONTEND_URL=https://to1.cloudit.lk
TEST_API_URL=https://to1.cloudit.lk/api/v1
PRODUCTION_FRONTEND_URL=https://po1.cloudit.lk
PRODUCTION_API_URL=https://po1.cloudit.lk/api/v1
