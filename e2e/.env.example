# Playwright E2E test configuration
# Copy this file to e2e/.env and fill in real values. e2e/.env is gitignored.

# Target environment
E2E_BASE_URL=https://to-admin.cloudit.lk

# Admin user credentials (must exist in the target environment)
E2E_ADMIN_EMAIL=pltadmin@cloudit.lk
E2E_ADMIN_PASSWORD=

# Optional: employee self-service credentials
E2E_EMPLOYEE_EMAIL=
E2E_EMPLOYEE_PASSWORD=

# Optional: API base URL for backend health/seed checks
E2E_API_URL=https://api-touchorbit.cloudit.lk
