# n8n — Workflow Automation
# https://docs.n8n.io/hosting/

# Domain
N8N_HOST=n8n.cloudit.example.com

# n8n config
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_password

# Security
N8N_ENCRYPTION_KEY=change_this_to_a_random_32_char_string

# Database — connects to shared postgres
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=cloudit
DB_POSTGRESDB_PASSWORD=change_this_to_a_strong_password

# Redis — for queue mode
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PASSWORD=change_this_to_a_strong_password

# Execution mode: regular (default) or queue (for scaling)
EXECUTIONS_MODE=regular

# Webhook URL (must match the public domain)
WEBHOOK_URL=https://n8n.cloudit.example.com

# Timezone
GENERIC_TIMEZONE=Europe/Berlin

# Disable telemetry
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
