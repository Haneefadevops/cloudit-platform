# Chatwoot application config
CHATWOOT_SECRET_KEY_BASE=change_this_to_a_long_random_string
CHATWOOT_FRONTEND_URL=https://inbox.thereplyte.com
CHATWOOT_DEFAULT_LOCALE=en
# Set to true only while creating the very first admin account; disable afterwards.
CHATWOOT_ENABLE_ACCOUNT_SIGNUP=false

# Reuse the existing Postgres server (database will be created in infra/postgres/init)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USER=cloudit
POSTGRES_PASSWORD=change_this_to_match_postgres_env

# Reuse the existing Redis server
REDIS_PASSWORD=change_this_to_match_redis_env

# SMTP for Chatwoot transactional emails (invites, password resets, notifications)
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=chatwoot@example.com
SMTP_PASSWORD=change_this_smtp_password
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=TheReplyte <noreply@thereplyte.com>

# Traefik domain override (must match infra/traefik/.env)
DOMAIN=thereplyte.com

# Enable the Platform API so third-party apps can create accounts/inboxes
ENABLE_PLATFORM_API=true
