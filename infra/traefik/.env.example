# Traefik Reverse Proxy
# Handles all HTTPS traffic, automatic Let's Encrypt, Cloudflare DNS challenge

CF_DNS_API_TOKEN=your_cloudflare_api_token_here
CF_ZONE_API_TOKEN=your_cloudflare_zone_token_here

# Domain configuration
DOMAIN=cloudit.example.com
ACME_EMAIL=admin@example.com

# Traefik dashboard auth (htpasswd format)
# Generate with: htpasswd -nb admin your_password
DASHBOARD_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# Traefik log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
