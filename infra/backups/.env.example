# CloudIT Backup Configuration
# Copy this file to .env and fill in real values.

# PostgreSQL credentials (same as infra/postgres/.env)
POSTGRES_USER=cloudit
POSTGRES_PASSWORD=changeme

# Redis password (same as infra/redis/.env)
REDIS_PASSWORD=changeme

# GPG passphrase used to encrypt backups.
# Generate a strong random value and keep it safe — you cannot restore without it.
BACKUP_ENCRYPTION_KEY=your-very-strong-random-passphrase

# Local backup directory and log file
BACKUP_DIR=/opt/backups/local
LOG_FILE=/var/log/cloudit-backup.log
BACKUP_RETENTION_DAYS=7

# Optional Hetzner Storage Box off-site sync
# HETZNER_STORAGE_BOX=backups
# HETZNER_RSYNC_URL=u12345@u12345.your-storagebox.de:backups
