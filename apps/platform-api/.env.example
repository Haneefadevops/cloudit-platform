PORT=3001
DATABASE_URL=postgresql://cloudit:changeme@postgres:5432/platform?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme
JWT_SECRET=your-jwt-secret-here
# Comma-separated whitelist. Use * to allow all origins (not recommended in production).
CORS_ORIGIN=http://localhost:3000,https://app.cloudit.lk
INTERNAL_API_TOKEN=your-internal-api-token-here

# Product API URLs used by the onboarding service to provision tenants.
# Use internal Docker service names in production/container networks.
TOUCHORBIT_API_URL=http://touchorbit-api:3006/api
ORBITONE_API_URL=http://orbitone-api:3004/api
HOSPITALITY_API_URL=http://hospitality-api:3002/api

# Product frontend URLs used in invite and welcome emails.
TOUCHORBIT_WEB_URL=https://touchorbit.cloudit.lk
ORBITONE_WEB_URL=https://orbitone.cloudit.lk
HOSPITALITY_WEB_URL=https://hospitality.cloudit.lk

# Email delivery webhook (optional). If not set, emails are logged only.
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_API_KEY=

# Rate limiting (default: 100 requests per minute)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# n8n Webhook Integration
N8N_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/cloudit-events
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here

# Super admin emails (comma-separated) allowed to manage organization modules
SUPER_ADMIN_EMAILS=admin@cloudit.lk

# AI Provider (openai | anthropic | local)
AI_PROVIDER=openai
AI_API_KEY=your-ai-api-key-here

# WhatsApp Business API Placeholders
WHATSAPP_API_KEY=your-whatsapp-api-key-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here
