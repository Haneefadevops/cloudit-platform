generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-platform"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  passwordHash String @map("password_hash")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  avatar    String?
  isActive  Boolean  @default(true) @map("is_active")
  emailVerified Boolean @default(false) @map("email_verified")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members        OrganizationMember[]
  auditLogs      AuditLog[]
  roles          Role[]
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  settings       Setting[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  plan      String   @default("free")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members         OrganizationMember[]
  auditLogs       AuditLog[]
  roles           Role[]
  settingsKV      Setting[]
  productModules  OrganizationProductModule[]
  provisioning    OrganizationProvisioning[]
  customFields    OrganizationCustomField[]
  featureFlags    OrganizationFeatureFlag[]

  @@index([slug])
  @@index([plan])
  @@map("organizations")
}

model OrganizationMember {
  id     String @id @default(uuid())
  userId String @map("user_id")
  orgId  String @map("org_id")
  role   OrganizationRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
  @@map("organization_members")
}

enum OrganizationRole {
  ADMIN
  MANAGER
  MEMBER
}

model Role {
  id          String   @id @default(uuid())
  name        String
  permissions Json     @default("[]")
  orgId       String   @map("org_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id])
  createdById  String?      @map("created_by_id")

  @@index([orgId])
  @@map("roles")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userId     String?  @map("user_id")
  orgId      String?  @map("org_id")
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(uuid())
  key       String
  value     Json
  orgId     String   @map("org_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation(fields: [createdById], references: [id])
  createdById  String?      @map("created_by_id")

  @@unique([key, orgId])
  @@index([orgId])
  @@map("settings")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

enum EventStatus {
  pending
  success
  failed
}

model EventLog {
  id             String      @id @default(uuid())
  eventType      String      @map("event_type")
  payload        Json        @default("{}")
  status         EventStatus @default(pending)
  webhookUrl     String?     @map("webhook_url")
  responseStatus Int?        @map("response_status")
  errorMessage   String?     @map("error_message")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("event_logs")
}

model IntegrationSetting {
  id                     String   @id @default(uuid())
  n8nWebhookUrl          String?  @map("n8n_webhook_url")
  n8nWebhookSecret       String?  @map("n8n_webhook_secret")
  aiProvider             String   @default("none") @map("ai_provider")
  aiApiKey               String?  @map("ai_api_key")
  whatsappApiKey         String?  @map("whatsapp_api_key")
  whatsappPhoneNumberId  String?  @map("whatsapp_phone_number_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("integration_settings")
}

model OrganizationProductModule {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  product   String
  moduleKey String   @map("module_key")
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, product, moduleKey])
  @@index([orgId])
  @@index([product])
  @@map("organization_product_modules")
}

model OrganizationProvisioning {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  product       String
  tenantId      String?   @map("tenant_id")
  userId        String?   @map("user_id")
  status        String    @default("pending")
  invitedEmail  String    @map("invited_email")
  inviteToken   String?   @map("invite_token")
  setPasswordUrl String?  @map("set_password_url")
  invitedAt     DateTime? @map("invited_at")
  activatedAt   DateTime? @map("activated_at")
  revokedAt     DateTime? @map("revoked_at")
  failureReason String?   @map("failure_reason")
  retryCount    Int       @default(0) @map("retry_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, product])
  @@index([product])
  @@index([status])
  @@map("organization_provisioning")
}

model OrganizationCustomField {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  product     String
  module      String
  entity      String
  fieldKey    String   @map("field_key")
  fieldLabel  String   @map("field_label")
  fieldType   String   @map("field_type")
  options     Json?
  required    Boolean  @default(false)
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, product, entity, fieldKey])
  @@index([orgId])
  @@index([product])
  @@index([entity])
  @@map("organization_custom_fields")
}

model OrganizationFeatureFlag {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  product     String
  featureKey  String   @map("feature_key")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, product, featureKey])
  @@index([orgId])
  @@index([product])
  @@map("organization_feature_flags")
}
