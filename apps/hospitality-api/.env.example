PORT=3002
DATABASE_URL=postgresql://cloudit:changeme@postgres:5432/hospitality?schema=public
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme
JWT_SECRET=your-jwt-secret-here
# Comma-separated whitelist. Use * to allow all origins (not recommended in production).
CORS_ORIGIN=http://localhost:3000,https://app.cloudit.lk
PLATFORM_API_URL=http://platform-api:3001/api

# Rate limiting (default: 100 requests per minute)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
INTERNAL_API_TOKEN=your-internal-api-token-here

# n8n Webhook Integration (optional)
N8N_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/cloudit-events
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here

# Communication webhooks (optional; connect these to n8n/provider workflows)
COMMUNICATION_EMAIL_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/hospitality-email
COMMUNICATION_SMS_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/hospitality-sms
COMMUNICATION_WHATSAPP_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/hospitality-whatsapp
COMMUNICATION_WEBHOOK_SECRET=your-communication-webhook-secret-here
COMMUNICATION_OWNER_EMAIL=owner@example.com

# Payment gateway checkout URLs (optional placeholders for provider-hosted checkout)
PAYHERE_CHECKOUT_URL=https://www.payhere.lk/pay/checkout
STRIPE_CHECKOUT_URL=https://checkout.stripe.com/c/pay
