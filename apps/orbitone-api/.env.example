PORT=3004
DATABASE_URL=postgresql://cloudit:changeme@postgres:5432/orbitone?schema=public

# Redis: either REDIS_URL or REDIS_HOST/PORT/PASSWORD
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

JWT_SECRET=your-jwt-secret-here
# Comma-separated whitelist. Use * to allow all origins (not recommended in production).
CORS_ORIGIN=http://localhost:3005,https://orbitone.${DOMAIN:-cloudit.lk}
# Legacy CORS variable; used as fallback if CORS_ORIGIN is not set.
FRONTEND_ORIGIN=http://localhost:3005

PLATFORM_API_URL=http://platform-api:3001/api

# Frontend URL used for invite/accept-invite links.
ORBITONE_WEB_URL=https://orbitone.cloudit.lk

INTERNAL_API_TOKEN=your-internal-api-token-here

# Rate limiting (default: 100 requests per minute)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# n8n Webhook Integration (optional)
N8N_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/cloudit-events
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_CALENDAR_REDIRECT_URI=
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_CALENDAR_SCOPES=ZohoCalendar.calendar.ALL,ZohoCalendar.event.ALL

# Calendar token encryption (optional, min 32 chars)
CALENDAR_TOKEN_ENCRYPTION_KEY=

LOG_LEVEL=info
