# Server
PORT=3010
NODE_ENV=development
# Public URL used for webhooks (Chatwoot, Meta)
API_PUBLIC_URL=https://api.thereplyte.com

# Database
# 'postgres' is the Docker service name on the cloudit network.
# Deploy will replace these placeholder credentials with the real ones from infra/postgres/.env.
DATABASE_URL=postgresql://cloudit:changeme@postgres:5432/whatsapp_agent?schema=public

# Security
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Meta WhatsApp API
META_API_BASE_URL=https://graph.facebook.com/v18.0
META_VERIFY_TOKEN=your_meta_webhook_verify_token
META_WEBHOOK_SECRET=your_meta_webhook_app_secret

# Kimi API
KIMI_API_KEY=your_kimi_api_key
KIMI_API_URL=https://api.moonshot.ai/v1/chat/completions
KIMI_MODEL=kimi-latest

# Embeddings (for knowledge base RAG)
# Defaults to the same provider as Kimi. OpenAI-compatible endpoint required.
EMBEDDING_API_URL=https://api.moonshot.ai/v1/embeddings
EMBEDDING_API_KEY=your_kimi_api_key
EMBEDDING_MODEL=moonshot-v3-embedding

# Chatwoot integration
CHATWOOT_PLATFORM_API_URL=http://chatwoot-rails:3000
CHATWOOT_PLATFORM_API_KEY=your_chatwoot_platform_api_key
# Account-scoped admin token and Chatwoot admin user id (must be a super admin)
CHATWOOT_ADMIN_API_KEY=your_chatwoot_admin_user_token
CHATWOOT_ADMIN_USER_ID=1
CHATWOOT_WEBHOOK_SECRET=your_webhook_secret_for_chatwoot_messages

# Chatwoot database (used only to auto-confirm newly created users and skip SMTP verification)
# These credentials must match infra/chatwoot/.env
CHATWOOT_DATABASE_URL=postgresql://cloudit:changeme@postgres:5432/chatwoot

# Optional n8n webhook for urgent handoff alerts
N8N_WEBHOOK_URL=

# CORS
CORS_ORIGIN=http://localhost:3011,https://app.thereplyte.com
