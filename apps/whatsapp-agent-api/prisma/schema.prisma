generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Client {
  id                    String   @id @default(uuid())
  name                  String
  whatsappNumber        String   @unique
  whatsappPhoneNumberId String   @unique
  metaAccessToken       String

  // Business information
  industry              String?
  website               String?
  timezone              String?  @default("UTC")
  language              String?  @default("en")
  businessDescription   String?

  // Primary admin contact (used for Chatwoot admin login)
  adminEmail            String?
  adminPhone            String?

  // Chatwoot integration
  chatwootAccountId     Int?
  chatwootInboxId       Int?
  chatwootApiKey        String?
  chatwootAdminUserId   Int?

  // AI settings (editable in AI Settings page)
  systemPrompt          String?  @default("You are a helpful AI assistant.")
  aiTemperature         Float?   @default(1.0)
  aiModel               String?  @default("kimi-latest")
  maxTokens             Int?     @default(1024)
  confidenceThreshold   Float?   @default(0.7)
  aiEnabled             Boolean  @default(true)
  welcomeMessage        String?  @default("Hello! How can we help you today?")
  fallbackMessage       String?  @default("We will connect you to one of our available agents.")
  handoffKeywords       String?  @default("human,agent,person,manager,supervisor")
  operatingHoursStart   String?  @default("09:00")
  operatingHoursEnd     String?  @default("17:00")
  closedDays            String?  @default("Saturday,Sunday")
  outsideHoursMessage   String?  @default("Thank you for contacting us! We are currently outside our business hours. Please leave your message and our team will get back to you as soon as we open.")

  // Customer satisfaction (CSAT)
  csatEnabled           Boolean  @default(true)
  csatMessage           String?  @default("Thank you for chatting with us! How would you rate your experience? Please reply with a number from 1 (poor) to 5 (excellent).")

  // Meta webhook
  verifyToken           String?  @default(uuid())
  webhookUrl            String?
  metaWebhookStatus     String?  @default("pending") // pending, active, error
  lastWebhookAt         DateTime?

  // Legacy fields (kept for backwards compatibility)
  businessProfile       Json?    @default("{}")
  products              Json?    @default("[]")

  status                String   @default("active") // active, paused, suspended
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customers       Customer[]
  conversations   Conversation[]
  users           User[]
  documents       Document[]
  cannedResponses CannedResponse[]

  @@map("clients")
}

model Customer {
  id          String   @id @default(uuid())
  phoneNumber String
  name        String?
  email       String?
  address     String?
  chatwootContactId Int?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId      String
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([clientId, phoneNumber])
  @@map("customers")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role            String   @default("agent") // admin, supervisor, agent
  status          String   @default("active") // active, away, offline
  chatwootUserId  Int?
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId      String?
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  conversations Conversation[]

  @@map("users")
}

model Conversation {
  id                      String    @id @default(uuid())
  status                  String    @default("bot") // bot, human, resolved, archived
  handoffReason           String?
  summary                 String?   // AI-generated summary, created on handoff
  chatwootConversationId  Int?
  chatwootContactId       Int?
  chatwootInboxId         Int?
  createdAt               DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  // CSAT state (set when resolved, filled when customer replies with a rating)
  csatPending             Boolean   @default(false)
  csatRating              Int?
  csatFeedback            String?

  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@index([clientId, status])
  @@index([assignedToId, status])
  @@map("conversations")
}

model Message {
  id           String   @id @default(uuid())
  senderType   String   // customer, bot, agent
  content      String
  kimiMetadata Json?    @default("{}")
  createdAt    DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model HandoffLog {
  id                  String    @id @default(uuid())
  triggeredBy         String    // bot, customer, agent, system
  reason              String?
  responseTimeSeconds Int?
  resolvedAt          DateTime?
  customerSatisfaction Int?
  createdAt           DateTime  @default(now())

  conversationId String
  assignedAgentId String?

  @@index([conversationId])
  @@map("handoff_logs")
}

model CannedResponse {
  id        String   @id @default(uuid())
  shortcut  String   // typed as "/shortcut" by agents in Chatwoot
  title     String
  content   String   // supports {{customer_name}}, {{business_name}}, {{agent_name}}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, shortcut])
  @@map("canned_responses")
}

model Document {
  id          String   @id @default(uuid())
  title       String
  content     String
  contentType String   @default("text") // text, pdf, docx, txt
  embedding   Unsupported("vector(1536)")?
  chunkIndex  Int      @default(0)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("documents")
}
