PORT=3006
DATABASE_URL=postgresql://cloudit:changeme@postgres:5432/touchorbit?schema=public

# Redis (provide REDIS_URL or separate host/port/password)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme
# REDIS_URL=redis://:changeme@redis:6379

JWT_SECRET=your-jwt-secret-here

# Comma-separated whitelist. Use * to allow all origins (not recommended in production).
# Include the public portal, admin portal, employee self-service portal, and kiosk.
CORS_ORIGIN=http://localhost:3007,http://localhost:3008,http://localhost:3009,http://localhost:3010,https://touchorbit.${DOMAIN:-cloudit.lk},https://to-admin.${DOMAIN:-cloudit.lk},https://to-employee.${DOMAIN:-cloudit.lk},https://to-kiosk.${DOMAIN:-cloudit.lk}
PLATFORM_API_URL=http://platform-api:3001/api

# Frontend URLs used for invite/set-password links.
TOUCHORBIT_WEB_URL=https://touchorbit.${DOMAIN:-cloudit.lk}
TOUCHORBIT_ADMIN_WEB_URL=https://to-admin.${DOMAIN:-cloudit.lk}
TOUCHORBIT_EMPLOYEE_WEB_URL=https://to-employee.${DOMAIN:-cloudit.lk}
TOUCHORBIT_KIOSK_URL=https://to-kiosk.${DOMAIN:-cloudit.lk}

# Cross-subdomain session cookie (set to the parent domain, e.g. .cloudit.lk)
SESSION_COOKIE_DOMAIN=${DOMAIN:-.cloudit.lk}

# Rate limiting (default: 100 requests per minute)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Module-gating internal API
INTERNAL_API_TOKEN=your-internal-api-token-here

# Storage (S3/MinIO)
S3_ENDPOINT=http://minio:9000
S3_BUCKET_PREFIX=touchorbit
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Task reminders cron secret
TASK_REMINDERS_CRON_SECRET=your-cron-secret-here

# n8n Webhook Integration (optional)
N8N_WEBHOOK_URL=https://n8n.cloudit.lk/webhook/cloudit-events
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here
